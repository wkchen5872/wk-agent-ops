#!/usr/bin/env bash
# pre-commit hook — 執行 Node.js 測試（npm test）
# 安裝方式：bash scripts/skills/install.sh node

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel)"

# ── 偵測是否有 JS/TS 檔案變更 ─────────────────────────────────────────────────

staged_node_files=$(git diff --cached --name-only | grep -E '\.(js|ts|jsx|tsx)$' || true)

if [[ -z "$staged_node_files" ]]; then
    exit 0
fi

# ── 確認 package.json 存在 ────────────────────────────────────────────────────

if [[ ! -f "$PROJECT_ROOT/package.json" ]]; then
    echo "ℹ️  未發現 package.json，跳過 Node.js 測試。"
    exit 0
fi

# ── 執行測試 ──────────────────────────────────────────────────────────────────

echo "🧪 執行 Node.js 測試..."

set +e
output=$(cd "$PROJECT_ROOT" && npm test 2>&1)
exit_code=$?
set -e

if [[ $exit_code -eq 0 ]]; then
    echo "✓ 所有測試通過，允許 commit。"
    exit 0
else
    echo "❌ 測試失敗，已阻止 commit。" >&2
    echo "$output" >&2
    exit 1
fi
