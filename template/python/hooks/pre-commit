#!/usr/bin/env bash
# pre-commit hook — 執行 tests/ unit tests（使用 pytest）
# 安裝方式：bash scripts/skills/install.sh python

set -euo pipefail

# ── 設定 ──────────────────────────────────────────────────────────────────────

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
LOG_DIR="$PROJECT_ROOT/logs"
TIMESTAMP="$(date +%Y%m%d_%H%M%S)"
LOG_FILE="$LOG_DIR/unit_test_${TIMESTAMP}.log"

# 選擇 Python 解譯器：優先使用專案 venv
if [[ -x "$PROJECT_ROOT/.venv/bin/python3" ]]; then
    PYTHON="$PROJECT_ROOT/.venv/bin/python3"
else
    PYTHON="python3"
fi

# 從 pyproject.toml 動態讀取 source 目錄（fallback: src）
# 支援：setuptools、poetry、pdm、hatch
if [[ -f "$PROJECT_ROOT/pyproject.toml" ]]; then
    SRC_DIR=$("$PYTHON" - <<'PYEOF'
import sys
try:
    import tomllib
except ImportError:
    try:
        import tomli as tomllib
    except ImportError:
        print("src"); sys.exit()

import os
pyproject = os.environ.get("PROJECT_ROOT", ".") + "/pyproject.toml"
with open(pyproject, "rb") as f:
    d = tomllib.load(f)
t = d.get("tool", {})

# setuptools: [tool.setuptools.packages.find] where = ["src"]
where = t.get("setuptools", {}).get("packages", {}).get("find", {}).get("where", [])
if where:
    print(where[0]); sys.exit()

# poetry: [[tool.poetry.packages]] from = "src"
pkgs = t.get("poetry", {}).get("packages", [])
if pkgs and "from" in pkgs[0]:
    print(pkgs[0]["from"]); sys.exit()

# pdm: [tool.pdm.build] package-dir = "src"
pkg_dir = t.get("pdm", {}).get("build", {}).get("package-dir", "")
if pkg_dir:
    print(pkg_dir); sys.exit()

# hatch: [tool.hatch.build.targets.wheel] packages = ["src/mypkg"]
hatch_pkgs = t.get("hatch", {}).get("build", {}).get("targets", {}).get("wheel", {}).get("packages", [])
if hatch_pkgs:
    print(os.path.dirname(hatch_pkgs[0])); sys.exit()

print("src")
PYEOF
    PROJECT_ROOT="$PROJECT_ROOT" 2>/dev/null || echo "src")
else
    SRC_DIR="src"
fi

mkdir -p "$LOG_DIR"

# ── 初始化計數 ────────────────────────────────────────────────────────────────

total_tests=0
total_failures=0
total_errors=0
failed_modules=()

# ── 寫入日誌 header ───────────────────────────────────────────────────────────

{
    echo "========================================"
    echo "Unit Test Run: $(date '+%Y-%m-%d %H:%M:%S')"
    echo "Python: $($PYTHON --version 2>&1)"
    echo "Project: $PROJECT_ROOT"
    echo "========================================"
    echo ""
} >> "$LOG_FILE"

# ── 逐目錄執行測試 ────────────────────────────────────────────────────────────

TEST_DIR="$PROJECT_ROOT/tests"

if [[ ! -d "$TEST_DIR" ]]; then
    echo "ℹ️  未發現 tests/ 目錄，允許 commit。" | tee -a "$LOG_FILE"
    exit 0
fi

test_dirs=("$TEST_DIR")

for test_dir in "${test_dirs[@]}"; do
    module="tests"

    echo "── ${module} ──────────────────────────────────────" >> "$LOG_FILE"

    # 執行測試，擷取輸出
    set +e
    output=$(PYTHONPATH="$PROJECT_ROOT/$SRC_DIR" "$PYTHON" -m pytest "$test_dir" -q --tb=short 2>&1)
    exit_code=$?
    set -e

    echo "$output" >> "$LOG_FILE"
    echo "" >> "$LOG_FILE"

    # 解析統計數字（pytest 輸出格式：2 failed, 5 passed, 1 error in X.XXs）
    passed=$(echo "$output" | grep -oE '[0-9]+ passed' | grep -oE '[0-9]+' || echo "0")
    fails=$(echo  "$output" | grep -oE '[0-9]+ failed' | grep -oE '[0-9]+' || echo "0")
    errors=$(echo "$output" | grep -oE '[0-9]+ error'  | grep -oE '[0-9]+' || echo "0")
    passed=${passed:-0}; fails=${fails:-0}; errors=${errors:-0}
    ran=$(( passed + fails + errors ))
    total_tests=$((total_tests + ran))

    # exit code 5 = no tests collected — not a failure
    if [[ $exit_code -ne 0 && $exit_code -ne 5 ]]; then
        failed_modules+=("$module")
        total_failures=$((total_failures + fails))
        total_errors=$((total_errors + errors))
    fi
done

# ── 寫入總結 ──────────────────────────────────────────────────────────────────

{
    echo "========================================"
    echo "總結 — Ran ${total_tests} tests"
    if [[ ${#failed_modules[@]} -eq 0 ]]; then
        echo "結果：全部通過 ✓"
    else
        echo "結果：FAILED"
        echo "  failures : $total_failures"
        echo "  errors   : $total_errors"
        echo "  失敗模組 : ${failed_modules[*]}"
    fi
    echo "========================================"
} >> "$LOG_FILE"

# ── 輸出至終端並決定結果 ──────────────────────────────────────────────────────

if [[ ${#failed_modules[@]} -eq 0 ]]; then
    echo "✓ 所有測試通過（共 ${total_tests} 個），允許 commit。"
    exit 0
else
    echo "❌ Unit tests 失敗，已阻止 commit。" >&2
    echo "   失敗模組：${failed_modules[*]}" >&2
    echo "   詳細結果：$LOG_FILE" >&2
    exit 1
fi
