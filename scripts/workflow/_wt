#compdef wt-new wt-done wt-resume

_wt() {
  local repo
  repo=$(git rev-parse --show-toplevel 2>/dev/null)

  if [[ -z "$repo" || ! -d "$repo/.worktrees" ]]; then
    return 0
  fi

  local -a features
  features=("${(@f)$(ls "$repo/.worktrees/" 2>/dev/null)}")

  _describe 'feature names' features
}

compdef _wt wt-new wt-done wt-resume
